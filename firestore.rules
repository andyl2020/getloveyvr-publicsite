rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isOperator() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in [
          "aluu.life@gmail.com"
        ];
    }

    function isValidPollOption() {
      return request.resource.data.option in [
        "ages_35_45",
        "ages_45_plus",
        "ikea",
        "costco",
        "baking",
        "karaoke_singles",
        "more_friend_events",
        "bring_back",
      ];
    }

    function isValidBringBackPick() {
      return request.resource.data.option == "bring_back"
        ? (
            request.resource.data.bring_back_pick == null
            || request.resource.data.bring_back_pick in ["boxing", "improv", "other"]
          )
        : request.resource.data.bring_back_pick == null;
    }

    function isValidWriteIn() {
      return request.resource.data.option == "bring_back"
        ? request.resource.data.bring_back_pick == null || request.resource.data.bring_back_pick == "other"
          ? (
              request.resource.data.write_in is string
              && request.resource.data.write_in.size() > 0
              && request.resource.data.write_in.size() <= 500
            )
          : request.resource.data.write_in == null
        : request.resource.data.option == "more_friend_events"
          ? (
              request.resource.data.write_in is string
              && request.resource.data.write_in.size() > 0
              && request.resource.data.write_in.size() <= 500
            )
          : request.resource.data.write_in == null;
    }

    function isValidVoteDocument() {
      return request.resource.data.keys().hasOnly([
          "session_id",
          "option",
          "bring_back_pick",
          "write_in",
          "created_at"
        ])
        && request.resource.data.session_id is string
        && request.resource.data.session_id.size() >= 16
        && request.resource.data.session_id.size() <= 128
        && request.resource.data.created_at == request.time
        && isValidPollOption()
        && isValidBringBackPick()
        && isValidWriteIn();
    }

    function isValidEmailAddress(value) {
      return value is string
        && value.size() >= 5
        && value.size() <= 320
        && value.matches('^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$');
    }

    function isValidMailingListDocument() {
      return request.resource.data.keys().hasOnly([
          "email",
          "normalized_email",
          "source",
          "created_at"
        ])
        && isValidEmailAddress(request.resource.data.email)
        && isValidEmailAddress(request.resource.data.normalized_email)
        && request.resource.data.normalized_email == request.resource.data.email.lower()
        && request.resource.data.source is string
        && request.resource.data.source.size() > 0
        && request.resource.data.source.size() <= 64
        && request.resource.data.created_at == request.time;
    }

    match /dashboard/{documentId} {
      allow read: if documentId == "event-schedule" || isOperator();
      allow write: if (documentId == "event-schedule" || documentId == "shared-state") && isOperator();
    }

    match /event_votes/{voteId} {
      allow get, list: if true;
      allow create: if isValidVoteDocument();
      allow update, delete: if false;
    }

    match /mailing_list_signups/{signupId} {
      allow get: if true;
      allow list: if isOperator();
      allow create: if isValidMailingListDocument();
      allow update, delete: if false;
    }
  }
}
